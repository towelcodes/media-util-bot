# bot token
DISCORD_TOKEN=your_bot_token_here

# optional guild id for faster command testing during development
GUILD_ID=your_guild_id_here

# optional: logging level
RUST_LOG=media_bot=info

# optional: endpoint for nekos.best API
NEKO_ENDPOINT=https://nekos.best/api/v2/

# database connection
DATABASE_URL=mysql://username:password@localhost:3306/media_bot_db

# owner user id
OWNER=1234567890

# request channel to send feature requests to
UPDATE_CHANNEL=1234567890
